{
  "_comment": "Parámetros de entrenamiento e hiperparámetros de modelos.",
  "_ubicacion": "src/params.json",

  "params": {
    "test_size":     0.20,
    "random_state":  42,
    "cv_splits":     5,
    "recall_minimo": 0.80
  },

  "hyperparameters": {
    "decision_tree": {
      "max_depth":    6,
      "random_state": 42,
      "class_weight": "balanced",
      "criterion":    "gini"
    },
    "random_forest": {
      "n_estimators": 100,
      "max_depth":    8,
      "random_state": 42,
      "n_jobs":      -1,
      "max_features": "sqrt",
      "bootstrap":    true,
      "oob_score":    true,
      "class_weight": "balanced"
    },
    "logistic_regression": {
      "C":            1.0,
      "max_iter":     1000,
      "random_state": 42,
      "solver":       "lbfgs",
      "penalty":      "l2"
    }
  }
}
